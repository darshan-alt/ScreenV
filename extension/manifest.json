{
  "manifest_version": 3,
  "name": "ScreenV1 Recorder",
  "version": "1.0",
  "description": "Record your screen and edit videos in the browser.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "desktopCapture"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
